@{
    ViewData["Title"] = "Hlavní stránka";
}

<div class="container mt-4">

    <!-- Hlavní nadpis a podnadpis -->
    <div class="text-center p-5 mb-4 bg-light rounded-3 shadow-sm">
        <h1 class="display-4 fw-bold">Školní Zasedací Pořádek</h1>
        <p class="fs-4 text-muted">Moderní správa zasedacích pořádků pro vaši školu.</p>
    </div>

    <!-- Ohraničený box s informacemi o aplikaci -->
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <h4 class="card-title">O Aplikaci</h4>
            <hr />
            <p class="card-text">
                Vítejte v digitálním systému pro správu zasedacích pořádků. Naše aplikace byla navržena s cílem zjednodušit a zefektivnit organizaci ve školních třídách pro učitele i žáky.
            </p>
            <p class="card-text">
                Systém poskytuje personalizovaný přístup na základě role uživatele:
            </p>
            <ul class="list-group list-group-flush mb-3">
                <li class="list-group-item">
                    <strong>Pro učitele:</strong> Plná kontrola nad tvorbou, úpravami a správou zasedacích pořádků. Učitelé mohou snadno přizpůsobit rozesazení žáků podle aktuálních potřeb výuky.
                </li>
                <li class="list-group-item">
                    <strong>Pro žáky:</strong> Rychlý a přehledný náhled na aktuální zasedací pořádek ve svých třídách. Již žádné zmatky na začátku hodiny.
                </li>
            </ul>
            
            <div class="text-center mt-4">
                <a class="btn btn-primary btn-lg" asp-area="" asp-controller="User" asp-action="Login">Přejít na přihlášení</a>
            </div>
        </div>
    </div>

</div>
