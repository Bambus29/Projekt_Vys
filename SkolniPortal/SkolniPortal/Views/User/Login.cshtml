@{
    ViewData["Title"] = "Login";
}
<div class="nastred">
    <h1>Login</h1>
    @if (ViewData["chyba"] != null)
    {
        <div class="error">@ViewData["chyba"]</div>
    }
    <form action="/User/Login" method="post">
        <div>
            <label>login (bez čísla):</label><br>               <!--login-->
            <input type="text" name="login">
            <a>(zavináč)spstrutnov.cz</a><br>
        </div>

        <div>
        <label>číslo loginu:</label><br>                        <!--číslo loginu-->
        <input type="number" name="login"><br>
        </div>

        <div>
        <label>Password:</label><br>
        <input type="password" name="password"><br />                      <!--heslo-->
        <input type="submit" value="Submit">
        </div>
    </form>

    nemáte účet? <a asp-controller="User" asp-action="Register">Zaregistrujte se</a>
</div>